# Pulse can authenticate gateway-routed model IDs with either a linked Vercel
# project/OIDC token or an AI Gateway API key.
#
# For the lowest-friction local setup, run:
#   vercel link
#   vercel env pull .env.local
#
# If you are not using Vercel OIDC locally, paste an AI Gateway key here.
AI_GATEWAY_API_KEY=

# Optional: override the Vercel Connect Slack connector UID used by
# agent/channels/slack.ts. Leave blank to use slack/vercel-eve-bot.
SLACK_CONNECTOR=
